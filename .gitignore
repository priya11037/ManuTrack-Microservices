# Create .gitignore
@"
# .NET
bin/
obj/
*.user
.vs/
*.suo
*.userprefs

# Angular
node_modules/
dist/
.angular/

# Environment/Secrets
appsettings.Development.json

# SQL generated scripts (optional — remove if you want to keep them)
create-*.sql

# Logs
*.log
"@ | Out-File -FilePath ".gitignore" -Encoding utf8